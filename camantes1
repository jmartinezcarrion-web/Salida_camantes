function guardarRuta() {
const nombre = document.getElementById(‘ruta-nombre’).value.trim();
const distancia = document.getElementById(‘ruta-dist’).value;
const desnivel = document.getElementById(‘ruta-desnivel’).value;
const desc = document.getElementById(‘ruta-desc’).value.trim();
const enlace = document.getElementById(‘ruta-enlace’).value.trim();
if (!nombre) { mostrarNotif(‘⚠️ Ponle un nombre a la ruta’); return; }
db.ref(‘rutas’).push({ nombre, distancia, desnivel, desc, enlace, ts: Date.now() })
.then(() => {
mostrarNotif(‘🗺️ ¡Ruta guardada!’);
document.querySelectorAll(’#form-ruta input, #form-ruta textarea’).forEach(el => el.value = ‘’);
document.getElementById(‘form-ruta’).style.display = ‘none’;
});
}

db.ref(‘rutas’).on(‘value’, (snap) => {
const cont = document.getElementById(‘lista-rutas’);
if (!cont) return;
if (!snap.exists()) {
cont.innerHTML = `<div class="card" style="text-align:center;padding:30px 20px"><div style="font-size:36px;margin-bottom:10px">🗺️</div><div style="font-family:'Barlow Condensed',sans-serif;font-size:16px;color:rgba(255,255,255,0.7)">No hay rutas guardadas aún.</div></div>`;
return;
}
const rutas = [];
snap.forEach(c => rutas.push({ id: c.key, …c.val() }));
cont.innerHTML = rutas.map(r => ` <div class="card"> <div class="card-header"><div class="avatar">🗺️</div><div class="card-meta"><div class="card-nombre">Ruta del club</div></div></div> <div class="card-titulo">${r.nombre}</div> ${r.desc?`<div class="card-desc">${r.desc}</div>`:''} <div class="card-datos">${r.distancia?`<span class="dato">📏 ${r.distancia} km</span>`:''} ${r.desnivel?`<span class="dato">⛰️ ${r.desnivel} m</span>`:''}</div> <div class="card-acciones">${r.enlace?`<a href="${r.enlace}" target="_blank" class="btn-sm" style="text-decoration:none">🔗 Ver ruta</a>`:''}</div> </div>`).join(’’);
document.querySelectorAll(’.stat-pill’)[1].innerHTML = `<strong>${rutas.length}</strong>Rutas`;
});

