<!-- NOTIF -->

<div class="notif" id="notif"></div>

<script>
  function irA(sec) {
    document.querySelectorAll('.seccion').forEach(s => s.classList.remove('visible'));
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('activo'));
    document.getElementById(sec).classList.add('visible');
    document.querySelector(`[data-sec="${sec}"]`)?.classList.add('activo');
    window.scrollTo({top: 0, behavior: 'smooth'});
  }

  function toggleApuntado(btn) {
    if (btn.classList.contains('apuntado')) {
      btn.classList.remove('apuntado');
      btn.textContent = '+ Apuntarme';
      mostrarNotif('❌ Te has desapuntado de la salida');
    } else {
      btn.classList.add('apuntado');
      btn.textContent = '✅ Apuntado';
      mostrarNotif('✅ ¡Te has apuntado a la salida!');
    }
  }

  function toggleFiltro(btn) {
    document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
  }

  function mostrarNotif(msg) {
    const n = document.getElementById('notif');
    n.textContent = msg;
    n.classList.add('show');
    setTimeout(() => n.classList.remove('show'), 3000);
  }

  function activarGPS() {
    mostrarNotif('📍 GPS activado — localizando...');
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        pos => mostrarNotif(`📍 Ubicado: ${pos.coords.latitude.toFixed(4)}, ${pos.coords.longitude.toFixed(4)}`),
        () => mostrarNotif('📍 GPS activado en modo demo')
      );
    }
  }

  function verComentarios() { irA('traba'); }

  // ===== CALENDARIO =====
  const meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  let calFecha = new Date();

  // Salidas marcadas manualmente en el calendario (formato: 'YYYY-M-D')
  const salidasCal = {};
  // Salidas reales de Firebase (formato: 'YYYY-M-D' -> nombre)
  window.salidasFirebaseCal = {};

  function renderCalendario() {
    const hoy = new Date();
    const anio = calFecha.getFullYear();
    const mes = calFecha.getMonth();
    document.getElementById('cal-titulo').textContent = meses[mes].toUpperCase() + ' ' + anio;

    const primerDia = new Date(anio, mes, 1).getDay();
    const diasMes = new Date(anio, mes + 1, 0).getDate();
    const offset = primerDia === 0 ? 6 : primerDia - 1;

    const grid = document.getElementById('cal-grid');
    grid.innerHTML = '';

    for (let i = 0; i < offset; i++) {
      grid.appendChild(document.createElement('div'));
    }

    for (let d = 1; d <= diasMes; d++) {
      const key = anio + '-' + mes + '-' + d;
      const esHoy = (d === hoy.getDate() && mes === hoy.getMonth() && anio === hoy.getFullYear());
      const tieneSalidaManual = salidasCal[key];
      const tieneSalidaReal = window.salidasFirebaseCal[key];
      const tieneSalida = tieneSalidaManual || tieneSalidaReal;

      // Colores:
      // Hoy → blanco con texto rojo
      // Salida real de Firebase → amarillo/naranja brillante
      // Salida manual → blanco semitransparente
      let bg, color, border;
      if (esHoy && tieneSalidaReal) {
        bg = '#FFD600'; color = '#990000'; border = '2px solid #FF8800';
      } else if (esHoy) {
        bg = 'rgba(255,255,255,0.9)'; color = '#990000'; border = '1px solid white';
      } else if (tieneSalidaReal) {
        bg = '#FF8C00'; color = 'white'; border = '2px solid #FFD600';
      } else if (tieneSalidaManual) {
        bg = 'rgba(255,255,255,0.22)'; color = 'white'; border = '1px solid rgba(255,255,255,0.5)';
      } else {
        bg = 'rgba(255,255,255,0.07)'; color = 'white'; border = '1px solid transparent';
      }

      const celda = document.createElement('div');
      celda.textContent = d;
      celda.style.cssText = `
        text-align:center;
        padding:6px 2px;
        border-radius:8px;
        font-family:'Barlow Condensed',sans-serif;
        font-size:15px;
        font-weight:${(esHoy || tieneSalidaReal) ? '700' : '400'};
        cursor:pointer;
        background:${bg};
        color:${color};
        border:${border};
        position:relative;
        transition:all 0.15s;
      `;

      if (tieneSalidaReal) {
        const punto = document.createElement('div');
        punto.style.cssText = 'width:5px;height:5px;background:white;border-radius:50%;margin:1px auto 0;';
        celda.appendChild(punto);
        celda.title = tieneSalidaReal;
      }

      celda.onclick = () => {
        if (tieneSalidaReal) {
          mostrarNotif('🚴 ' + tieneSalidaReal);
        } else {
          marcarSalida(key, d, mes, anio, celda);
        }
      };
      grid.appendChild(celda);
    }

    // Mostrar salidas del mes (manuales + reales)
    const lista = document.getElementById('cal-salidas-lista');
    const todasSalidas = {};
    Object.entries(salidasCal).forEach(([k,v]) => { if (k.startsWith(anio+'-'+mes+'-')) todasSalidas[k] = { nombre: v, tipo: 'manual' }; });
    Object.entries(window.salidasFirebaseCal).forEach(([k,v]) => { if (k.startsWith(anio+'-'+mes+'-')) todasSalidas[k] = { nombre: v, tipo: 'real' }; });

    if (Object.keys(todasSalidas).length > 0) {
      lista.innerHTML = '<div style="font-family:\'Barlow Condensed\',sans-serif;font-size:11px;letter-spacing:2px;color:rgba(255,255,255,0.5);margin-bottom:8px">SALIDAS ESTE MES</div>' +
        Object.entries(todasSalidas).sort().map(([k,v]) => {
          const dia = k.split('-')[2];
          const esReal = v.tipo === 'real';
          return `<div style="background:${esReal ? 'rgba(255,140,0,0.25)' : 'rgba(255,255,255,0.1)'};border-left:3px solid ${esReal ? '#FF8C00' : 'rgba(255,255,255,0.3)'};border-radius:0 8px 8px 0;padding:8px 12px;margin-bottom:5px;font-size:13px;display:flex;gap:8px;align-items:center">
            <span style="font-family:'Bebas Neue',sans-serif;font-size:20px;min-width:28px">${dia}</span>
            <span style="flex:1">${v.nombre}</span>
            ${esReal ? '<span style="font-size:10px;background:#FF8C00;border-radius:8px;padding:2px 7px;font-family:\'Barlow Condensed\',sans-serif;letter-spacing:1px">SALIDA</span>' : ''}
          </div>`;
        }).join('');
    } else {
      lista.innerHTML = '';
    }
  }
    if (salidasMes.length > 0) {
      lista.innerHTML = '<div style="font-family:\'Barlow Condensed\',sans-serif;font-size:11px;letter-spacing:2px;color:rgba(255,255,255,0.5);margin-bottom:6px">SALIDAS ESTE MES</div>' +
        salidasMes.map(([k,v]) => {
          const dia = k.split('-')[2];
          return `<div style="background:rgba(255,255,255,0.1);border-radius:8px;padding:8px 12px;margin-bottom:4px;font-size:13px;display:flex;gap:8px;align-items:center">
            <span style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:white;min-width:28px">${dia}</span>
            <span>${v}</span>
          </div>`;
        }).join('');
    } else {
      lista.innerHTML = '';
    }
  }

  function marcarSalida(key, dia, mes, anio, celda) {
    if (salidasCal[key]) {
      delete salidasCal[key];
      mostrarNotif('🗑️ Salida eliminada del día ' + dia);
    } else {
      const nombre = prompt('¿Qué salida hay el día ' + dia + ' de ' + meses[mes] + '?');
      if (nombre && nombre.trim()) {
        salidasCal[key] = nombre.trim();
        mostrarNotif('✅ Salida añadida al día ' + dia);
      }
    }
    renderCalendario();
  }

  function cambiarMes(dir) {
    calFecha.setMonth(calFecha.getMonth() + dir);
    renderCalendario();
  }

  renderCalendario();

  function enviarMsg() {
    const input = document.getElementById('chat-input');
    const texto = input.value.trim();
    if (!texto) return;
    const msgs = document.getElementById('chat-msgs');
    const msg = document.createElement('div');
    msg.className = 'msg propio';
    msg.innerHTML = `<div class="msg-avatar">😊</div><div><div class="msg-nombre" style="text-align:right">TÚ</div><div class="msg-burbuja">${texto}</div></div>`;
    msgs.appendChild(msg);
    msgs.scrollTop = msgs.scrollHeight;
    input.value = '';
  }
</script>

</body>
