function publicarSalida() {
const nombre = document.getElementById(‘in-nombre’).value.trim();
const fecha = document.getElementById(‘in-fecha’).value;
const hora = document.getElementById(‘in-hora’).value;
const punto = document.getElementById(‘in-punto’).value.trim();
const distancia = document.getElementById(‘in-distancia’).value;
const desnivel = document.getElementById(‘in-desnivel’).value;
const dificultad = document.getElementById(‘in-dificultad’).value;
const plazas = document.getElementById(‘in-plazas’).value;
const desc = document.getElementById(‘in-desc’).value.trim();
const gpx = document.getElementById(‘in-gpx’).value.trim();
if (!nombre || !fecha) { mostrarNotif(‘⚠️ Pon al menos el nombre y la fecha’); return; }
db.ref(‘salidas’).push({ nombre, fecha, hora, punto, distancia, desnivel, dificultad, plazas, desc, gpx, ts: Date.now() })
.then(() => {
mostrarNotif(‘🚴 ¡Salida publicada! Todos los camantes la verán’);
document.querySelectorAll(’#proponer input, #proponer textarea’).forEach(el => el.value = ‘’);
irA(‘salidas’);
})
.catch(e => mostrarNotif(’❌ Error: ’ + e.message));
}

